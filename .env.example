# Todoist API token: Todoist -> Settings -> Integrations -> Developer
TODOIST_API_KEY=

# llama.cpp's OpenAI-compatible endpoint. Defaults suit a local `llama-server`.
LLAMA_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_API_KEY=local
LLAMA_MODEL=local-model

# Shared token for the HTTP server (src/server.ts).
# Leave it empty only on a trusted LAN — empty means no authentication at all.
# Generate one with: openssl rand -hex 32
AGENT_TOKEN=

# Port the HTTP server listens on.
PORT=8787
